# Copy this file to .env and change the values
# NEVER commit .env to git — it's in .gitignore

AUTH_USER=admin
AUTH_PASS=password123
PORT=5000

# Log transport: local | direct | alloy
LOG_TRANSPORT=local
LOG_LEVEL=info

# Grafana Cloud Loki (required for LOG_TRANSPORT=direct)
# Get these from: Grafana Cloud → Connections → Loki → Push URL
LOKI_URL=
LOKI_USER=
LOKI_TOKEN=
